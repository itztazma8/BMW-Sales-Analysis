        <zone h='4779' id='5' leg-item-layout='horz' name='RA [EU]' pane-specification-id='0' param='[federated.0tmvpep0aspopg15uasxa1mb1the].[none:Model:nk]' type-v2='color' w='96933' x='3593' y='75735' />
        <zone h='39338' id='6' name='RA[CHN]' w='24978' x='25153' y='35478' />
        <zone h='39890' id='7' name='RA[ROTW]' w='25198' x='74626' y='35294' />
        <zone forceUpdate='true' h='25919' id='8' type-v2='text' w='21560' x='21911' y='1287'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontsize='15'>Highest Revenue</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>China</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>401.7B</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='25551' id='9' type-v2='text' w='22612' x='45837' y='735'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontsize='15'>Highest Revenue Recorded</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>2025</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>215.6 Billion</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='23162' id='10' type-v2='text' w='27870' x='71429' y='1287'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontsize='15'>Most Successful Model</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>X7</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='14'>745.9 Million</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='10662' id='11' type-v2='text' w='95618' x='2892' y='86765'>
          <formatted-text>
            <run fontcolor='#000000'>The </run>
            <run bold='true' fontcolor='#000000'>BMW x7 </run>
            <run fontcolor='#000000'>model is the most successful one over the years. But, a significant shift can be seen in case of </run>
            <run bold='true' fontcolor='#000000'>USA</run>
            <run fontcolor='#000000'> and </run>
            <run bold='true' fontcolor='#000000'>China </run>
            <run fontcolor='#000000'>where </run>
            <run bold='true' fontcolor='#000000'>x5 </run>
            <run fontcolor='#000000'>and </run>
            <run bold='true' fontcolor='#000000'>iX </run>
            <run fontcolor='#000000'>models are generating more average revenue although in </run>
            <run bold='true' fontcolor='#000000'>Europe </run>
            <run fontcolor='#000000'>and </run>
            <run bold='true' fontcolor='#000000'>Rest Of The World</run>
            <run fontcolor='#000000'>, </run>
            <run bold='true' fontcolor='#000000'>x7 </run>
            <run fontcolor='#000000'>is still dominating heavily during 2024-2025.</run>
            <run bold='true' fontcolor='#000000'>Æ </run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{9C80D99A-C274-4188-981E-3461249226BC}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='Sales &amp; GDP Dashboard'>
      <style>
        <style-rule element='dash-text'>
          <format attr='text-orientation' id='dash-text_2' value='0' />
        </style-rule>
      </style>
      <size maxheight='543' maxwidth='1119' minheight='543' minwidth='1119' preset-index='1' sizing-mode='fixed' />
      <zones>
        <zone h='97610' id='1' is-centered='0' is-scaled='1' param='C:/Users/HP/Downloads/Bg1.jpg' type-v2='bitmap' w='99649' x='526' y='551' />
        <zone forceUpdate='true' h='40257' id='2' type-v2='text' w='10188' x='715' y='1103'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontsize='20'>Sales Analysis &amp;</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontsize='20'>State of GDP</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='60110' id='3' type-v2='text' w='10545' x='357' y='38235'>
          <formatted-text>
            <run fontcolor='#000000'>The nominal GDP is seen to be very different for different regions which contradicts </run>
            <run bold='true' fontcolor='#4e79a7'>long term GDP</run>
            <run fontcolor='#000000'>. Also, the sales numbers are diverting from relying on only one model like it was before. We are seeing </run>
            <run bold='true' fontcolor='#4e79a7'>x5, x3, iX</run>
            <run fontcolor='#000000'> models performing well in sales.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000'>N.B: All nominal analysis have been done on 2024-25. </run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='12316' id='4' type-v2='text' w='14656' x='11707' y='735'>
          <formatted-text>
            <run fontcolor='#ffffff' fontsize='14'>Avg Units Sold</run>
